---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { casos } from '../data/casos';
---

<BaseLayout
  title="Casos de éxito"
  description="Programas reales de bienestar y formación implantados en empresas. Próximamente, vídeos, imágenes y resultados de los proyectos de Batmotrópicos."
  path="/casos-de-exito"
>
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:760px">
        <p class="eyebrow">Resultados</p>
        <h1 class="h2" style="font-size:38px">Casos de éxito</h1>
        <p class="lead">
          Programas reales implantados en empresas. Conforme cerramos cada proyecto, incorporamos
          aquí vídeos, imágenes y resultados con el consentimiento de cada cliente.
        </p>
      </div>

      <div class="casos">
        {
          casos.map((c) => (
            <article class="caso card card--accent reveal">
              <div class="caso__media">
                {c.videoSrc ? (
                  <video
                    src={c.videoSrc}
                    controls
                    preload="metadata"
                    playsinline
                    class="caso__video"
                  />
                ) : (
                  <div class="caso__placeholder">
                    <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" />
                      <path d="M10 8.5 L16 12 L10 15.5 Z" fill="currentColor" stroke="none" />
                    </svg>
                    <span>Material audiovisual próximamente</span>
                  </div>
                )}
              </div>
              <div class="caso__body">
                <div class="caso__head">
                  <h2 class="caso__title">{c.empresa}</h2>
                  {c.estado === 'proximamente' && <span class="badge">Próximamente</span>}
                </div>
                <p class="caso__sector">{c.sector}</p>
                <dl class="caso__rows">
                  <div><dt>Objetivo</dt><dd>{c.objetivo}</dd></div>
                  <div><dt>Acción</dt><dd>{c.accion}</dd></div>
                  <div><dt>Feedback</dt><dd>{c.feedback}</dd></div>
                </dl>
                {
                  c.linkedin && (
                    <a href={c.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                      Ver en LinkedIn <span class="arrow">→</span>
                    </a>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="¿Quieres ser el próximo?"
    title="Construyamos tu caso de éxito"
    text="Diseñamos un programa a medida, lo implantamos con tu equipo y medimos los resultados. Empieza por el diagnóstico."
  />
</BaseLayout>

<style>
  .casos {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .caso {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 32px;
    padding: 26px;
    align-items: center;
  }
  .caso__media {
    width: 100%;
  }
  .caso__video {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--line);
  }
  .caso__placeholder {
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    border: 1px dashed var(--line);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--green);
  }
  .caso__placeholder span {
    font-size: 12.5px;
    color: var(--text-sec);
  }
  .caso__head {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .caso__title {
    font-weight: 700;
    font-size: 21px;
    color: var(--text);
    margin: 0;
  }
  .caso__sector {
    font-weight: 500;
    font-size: 13px;
    color: var(--green-accent);
    margin: 6px 0 14px;
  }
  .caso__rows {
    margin: 0 0 18px;
  }
  .caso__rows > div {
    display: flex;
    gap: 12px;
    padding: 9px 0;
    border-bottom: 1px solid var(--line);
  }
  .caso__rows dt {
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green-accent);
    min-width: 80px;
    flex-shrink: 0;
  }
  .caso__rows dd {
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 820px) {
    .caso {
      grid-template-columns: 1fr;
      gap: 22px;
    }
  }
</style>
