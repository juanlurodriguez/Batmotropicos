---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { catalogo, BONIF_NOTE } from '../data/catalogo';

const queHacemosMain = [
  ['Formación bonificable', 'Acciones presenciales y online, diseñadas para encajar en el crédito FUNDAE de la empresa.'],
  ['Bienestar laboral', 'Ergonomía, estrés, comunicación y hábitos saludables aplicados al puesto.'],
  ['Team building y cohesión', 'Experiencias diseñadas para activar y conectar equipos, más allá de la actividad puntual.'],
];

const queHacemosComplementario = [
  'Wellness in company',
  'Formación técnica y obligatoria',
  'Programas semestrales / anuales',
];

const filosofia = [
  'Menos desgaste',
  'Más pertenencia',
  'Mejor experiencia de equipo',
];

const beneficios = [
  ['Reduce el desgaste físico y mental', 'Menos molestias, menos estrés acumulado y más energía sostenible.'],
  ['Mejora el clima laboral', 'Equipos que se cuidan colaboran mejor y discuten menos.'],
  ['Refuerza el sentido de pertenencia', 'El cuidado del equipo se traduce en compromiso con la empresa.'],
  ['Facilita el trabajo de RRHH', 'Formación, bienestar y team building gestionados por un solo equipo, con la documentación ordenada.'],
];

const proceso = ['Diagnóstico', 'Diseño', 'Gestión FUNDAE previa', 'Ejecución', 'Medición y cierre'];
---

<BaseLayout
  title="Bienestar corporativo y formación bonificable para empresas"
  description="Batmotrópicos activa personas para que los equipos funcionen mejor: formación bonificable FUNDAE, bienestar laboral, team building y wellness in company."
  path="/"
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero__grid">
      <div class="reveal">
        <p class="eyebrow">Formación · Bienestar · Cohesión</p>
        <h1 class="title">{site.claim}</h1>
        <p class="hero__sub">{site.subclaim}</p>
        <p class="hero__hook">
          Diseñado para reducir la rotación, el absentismo y el desgaste — y mejorar el clima de
          equipos que trabajan bajo presión.
        </p>
        <div class="hero__actions">
          <a href="/contacto" class="btn btn--primary">Solicitar diagnóstico 360º <span class="arrow">→</span></a>
          <a href="/catalogo" class="btn btn--outline">Ver catálogo</a>
        </div>
        <ul class="hero__pills">
          <li>Bonificable vía FUNDAE</li>
          <li>Propuesta en 48h</li>
          <li>Presencial y online</li>
        </ul>
      </div>

      <div class="reveal hero__panel card card--accent">
        <p class="eyebrow">Cómo empezamos</p>
        <h2 class="hero__panel-title">Diagnóstico 360º</h2>
        <p class="hero__panel-lead">
          Antes de proponer nada, miramos al equipo de cerca. Sin diagnóstico no hay plan que
          encaje de verdad.
        </p>
        <ol class="hero__steps">
          <li>
            <span class="hero__step-n">01</span>
            <div>
              <strong>Detectamos</strong> las prioridades reales del equipo: salud, clima, formación
              o cohesión.
            </div>
          </li>
          <li>
            <span class="hero__step-n">02</span>
            <div>
              <strong>Diseñamos</strong> un plan a medida y revisamos el encaje con el crédito FUNDAE.
            </div>
          </li>
          <li>
            <span class="hero__step-n">03</span>
            <div>
              <strong>Medimos</strong> resultados y proponemos continuidad, sin sobrecargar a RRHH.
            </div>
          </li>
        </ol>
        <div class="hero__panel-foot">
          <Icon size={26} />
          <span>Propuesta a medida en 48 horas</span>
        </div>
      </div>
    </div>
  </section>

  <!-- REEL VISUAL -->
  <section class="section section--reel">
    <div class="wrap reel__wrap">
      <div class="reel__text reveal">
        <p class="eyebrow">Así trabajamos</p>
        <h2 class="h2">Formación y bienestar aplicados al entorno real de trabajo.</h2>
        <p class="lead">
          Sin actividades desconectadas del puesto ni dinámicas que no se trasladan al día a día.
          Cada intervención parte de un diagnóstico real y se mide en resultados concretos.
        </p>
        <a href="/que-hacemos" class="btn btn--outline" style="margin-top:22px">Conocer la metodología <span class="arrow">→</span></a>
      </div>
      <div class="reel__media reveal">
        <video
          id="hero-reel"
          class="reel__video"
          src="/assets/video/hero-reel.mp4"
          muted
          loop
          playsinline
          preload="none"
          controls
          aria-label="Sesión presencial de formación y bienestar laboral para equipos de empresa"
        ></video>
      </div>
    </div>
  </section>

  <!-- QUÉ HACEMOS -->
  <section class="section">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Qué hacemos</p>
        <h2 class="h2">Una sola vía para RRHH</h2>
        <p class="lead">
          Centralizamos formación, bienestar corporativo y experiencias de cohesión para que RRHH
          tenga una propuesta clara, una ejecución coordinada y menos proveedores que gestionar.
        </p>
      </div>

      <div class="qh-main">
        {
          queHacemosMain.map(([t, d], i) => (
            <div class="qh-main__item reveal">
              <span class="qh-main__num">0{i + 1}</span>
              <h3 class="qh-main__title">{t}</h3>
              <p class="card-text">{d}</p>
            </div>
          ))
        }
      </div>

      <div class="qh-comp reveal">
        <span class="qh-comp__label">También cubrimos</span>
        <ul class="qh-comp__list">
          {queHacemosComplementario.map((t) => <li>{t}</li>)}
        </ul>
      </div>

      <div class="reveal" style="margin-top:30px">
        <a href="/que-hacemos" class="btn btn--outline">Conocer el enfoque <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- FILOSOFÍA (contraste verde oscuro) -->
  <section class="section section--dark">
    <div class="wrap dark__grid">
      <div class="reveal">
        <p class="eyebrow eyebrow--light">Nuestra filosofía</p>
        <h2 class="h2 h2--light">
          Para empresas que no quieren hacer actividades sueltas, sino construir una cultura de
          cuidado medible.
        </h2>
      </div>
      <ul class="dark__list reveal">
        {
          filosofia.map((f, i) => (
            <li>
              <span class="dark__num">0{i + 1}</span>
              <span>{f}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CATÁLOGO PREVIEW -->
  <section class="section section--soft">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Catálogo</p>
        <h2 class="h2">Todo lo que necesita un equipo, en un catálogo</h2>
        <p class="lead">
          Formación, bienestar, cohesión y servicios wellness organizados por áreas. Un solo equipo
          que conoce el contexto y propone lo que encaja.
        </p>
      </div>
      <div class="areas">
        {
          catalogo.map((c) => (
            <a href="/catalogo" class="areas__card card card--accent reveal">
              <span class="areas__letter" aria-hidden="true">{c.letter}</span>
              <h3 class="areas__title">{c.tab}</h3>
              <p class="areas__desc">{c.desc}</p>
              <span class="areas__count">{c.items.length} acciones</span>
            </a>
          ))
        }
      </div>
      <p class="note reveal" style="margin-top:18px; max-width:740px">{BONIF_NOTE}</p>
      <div class="reveal" style="margin-top:24px">
        <a href="/catalogo" class="btn btn--primary">Explorar el catálogo completo <span class="arrow">→</span></a>
      </div>

    </div>
  </section>

  <!-- BIENESTAR EN EL TERRENO -->
  <section class="section">
    <div class="wrap">
      <div class="real-block reveal card card--accent">
        <div class="real-block__media">
          <img
            src="/assets/img/real/kokomo-formacion.webp"
            alt="Formador dirigiéndose a un equipo de hostelería durante una sesión presencial de bienestar laboral"
            class="real-block__img"
            loading="lazy"
            decoding="async"
            width="1200"
            height="2133"
          />
        </div>
        <div class="real-block__body">
          <p class="eyebrow">En el terreno</p>
          <h2 class="h2" style="margin-bottom:14px">Bienestar aplicado al entorno real de trabajo.</h2>
          <p class="lead" style="margin-bottom:20px">Diseñamos acciones prácticas para que los equipos aprendan, se activen y puedan aplicar lo trabajado en su día a día laboral.</p>
          <details class="real-block__video-wrap">
            <summary class="real-block__video-btn">
              <span>▶ Ver sesión real</span>
            </summary>
            <video
              src="/assets/video/0609 (1)-1.mp4"
              controls
              preload="none"
              playsinline
              class="real-block__video"
              aria-label="Sesión presencial de formación en bienestar laboral para equipos de hostelería"
            ></video>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="section">
    <div class="wrap">
      <div class="ben-head">
        <div class="reveal">
          <p class="eyebrow">Beneficios</p>
          <h2 class="h2">Lo que gana la empresa</h2>
        </div>
        <p class="reveal ben-head__txt">
          No es un gasto en actividades sueltas: es una forma estructurada de cuidar al equipo que
          repercute en clima, retención y rendimiento.
        </p>
      </div>
      <div class="ben">
        {
          beneficios.map(([t, d], i) => (
            <div class="ben__item reveal">
              <span class="ben__num">0{i + 1}</span>
              <div>
                <h3 class="ben__title">{t}</h3>
                <p class="card-text">{d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PERTENENCIA -->
  <section class="section section--pertenencia">
    <div class="wrap">
      <div class="perten reveal">
        <p class="eyebrow">Por qué el bienestar retiene</p>
        <h2 class="h2 perten__title">El salario importa. Pero no es suficiente para quedarse.</h2>
        <div class="perten__body">
          <p>
            Si el sueldo es insuficiente, la persona se va. Eso es innegociable. Pero cuando el
            salario deja de ser el problema, la motivación no se sostiene solo con dinero. Una
            subida puede generar un pico de motivación, pero ese efecto se enfría.
          </p>
          <p>
            Lo que realmente une a una persona a una empresa es sentir que trabaja en un lugar
            donde se cuida a las personas, donde los valores encajan y donde formar parte del
            equipo tiene sentido.
          </p>
          <p class="perten__callout">
            La cultura de cuidado no es un extra. Es lo que hace que alguien quiera seguir.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- RECONOCIMIENTO -->
  <section class="section">
    <div class="wrap reconoc__grid reveal">
      <div class="reconoc__text">
        <p class="eyebrow">Reconocimiento</p>
        <h2 class="h2">Reconocimiento interno de compromiso con el bienestar laboral.</h2>
        <p class="lead">
          Al cierre de cada programa, la empresa recibe una placa que refleja el compromiso real
          con el cuidado de su equipo. No es una certificación oficial externa: es un símbolo de
          que el bienestar forma parte de la cultura de la organización.
        </p>
        <p class="note" style="margin-top:14px">
          El equipo también recibe diplomas individuales del trabajo realizado.
        </p>
      </div>
      <div class="reconoc__media">
        <div class="reconoc__plaque-placeholder">
          <span class="reconoc__plaque-icon">🏆</span>
          <p>Placa corporativa</p>
          <span class="reconoc__plaque-note">Fotografía próximamente</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMAS PREMIUM -->
  <section class="section section--soft">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Programas</p>
        <h2 class="h2">Una estructura para cada tipo de empresa</h2>
        <p class="lead">
          Desde una acción puntual hasta un programa anual integral. Cada nivel de compromiso tiene
          su propia estructura, su seguimiento y su medición de resultados.
        </p>
      </div>
      <div class="progs reveal">
        <div class="progs__item card card--accent">
          <span class="progs__tag">Continuidad</span>
          <h3 class="progs__title">Plan Semestral</h3>
          <p class="progs__meta">6 meses · 6 acciones · 1 al mes</p>
          <p class="card-text">Una intervención mensual con hilo conductor, seguimiento trimestral y memoria de resultados al cierre. Para empresas que quieren empezar con estructura y sin sobredimensionar.</p>
        </div>
        <div class="progs__item card card--accent progs__item--featured">
          <span class="progs__tag progs__tag--light">Recomendado</span>
          <h3 class="progs__title">Plan Anual</h3>
          <p class="progs__meta">12 acciones · 12 meses · evaluación semestral</p>
          <p class="card-text">Programa completo con una acción mensual, evaluación a mitad de año y propuesta de continuidad basada en resultados. Un solo equipo gestiona el plan, la documentación y el seguimiento.</p>
        </div>
        <div class="progs__item card card--accent">
          <span class="progs__tag">Integral</span>
          <h3 class="progs__title">Plan Integral Anual</h3>
          <p class="progs__meta">Formación + bienestar + team building + medición</p>
          <p class="card-text">El programa más completo: diagnóstico inicial, diseño a medida, ejecución de acciones de formación, bienestar y cohesión, y medición de impacto al cierre. Para empresas con visión de medio plazo.</p>
        </div>
      </div>
      <div class="reveal" style="margin-top:28px">
        <a href="/contacto" class="btn btn--primary">Solicitar propuesta de programa <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- MÉTODO -->
  <section class="section section--soft">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Cómo trabajamos</p>
        <h2 class="h2">Diagnóstico, gestión, ejecución y medición</h2>
        <p class="lead">
          Del primer diagnóstico al cierre documental. La gestión FUNDAE se prepara antes de ejecutar,
          no después. Al final recogemos KPIs: satisfacción, utilidad percibida, aplicabilidad y
          clima del equipo.
        </p>
      </div>
      <ol class="proc reveal">
        {
          proceso.map((s, i) => (
            <li class="proc__step">
              <span class="proc__dot">{i + 1}</span>
              <span class="proc__label">{s}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- JUAN LUIS TEASER -->
  <section class="section section--soft">
    <div class="wrap jl-teaser reveal">
      <div class="jl-teaser__media">
        <img
          src="/assets/img/real/juanlu.webp"
          alt="Juan Luis Rodríguez, fundador de Batmotrópicos"
          class="jl-teaser__img"
          loading="lazy"
          decoding="async"
          width="1200"
          height="1200"
        />
      </div>
      <div class="jl-teaser__body">
        <p class="eyebrow">Quiénes somos</p>
        <h2 class="h2">Detrás de Batmotrópicos hay una persona con oficio.</h2>
        <p class="lead">
          Juan Luis Rodríguez Ávila combina fisioterapia, deporte y formación con años de
          experiencia en hostelería y trabajo con grupos. Batmotrópicos nace de unir todo eso en
          una forma de hacer formación que conecta con las personas.
        </p>
        <a href="/quienes-somos" class="btn btn--outline" style="margin-top:18px">Conocer la historia <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script is:inline>
  (function () {
    var v = document.getElementById('hero-reel');
    if (!v) return;
    if (window.matchMedia('(min-width: 980px)').matches) {
      v.removeAttribute('controls');
      v.setAttribute('preload', 'metadata');
      v.play().catch(function () {});
    }
  })();
</script>

<style>
  /* Hero */
  .hero {
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
    padding-top: 84px;
    padding-bottom: 76px;
  }
  .hero__sub {
    font-size: 18px;
    color: var(--text-sec);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 0 18px;
  }
  .hero__hook {
    font-weight: 500;
    font-size: 14.5px;
    color: var(--green-dark);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 0 30px;
    padding-left: 16px;
    border-left: 2px solid var(--green);
  }
  .hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero__pills {
    list-style: none;
    margin: 30px 0 0;
    padding: 22px 0 0;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .hero__pills li {
    position: relative;
    font-weight: 500;
    font-size: 13px;
    color: var(--text-sec);
  }
  .hero__pills li:not(:first-child)::before {
    content: '';
    position: absolute;
    left: -12px;
    top: 50%;
    width: 4px;
    height: 4px;
    border-radius: 4px;
    background: var(--line);
    transform: translateY(-50%);
  }
  .hero__panel {
    padding: 38px 36px;
    background: #fff;
  }
  .hero__panel-title {
    font-weight: 700;
    font-size: 26px;
    color: var(--text);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .hero__panel-lead {
    font-size: 15px;
    color: var(--text-sec);
    line-height: 1.65;
    margin: 0 0 26px;
  }
  .hero__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .hero__steps li {
    display: grid;
    grid-template-columns: 34px 1fr;
    gap: 14px;
    align-items: baseline;
  }
  .hero__steps li > div {
    font-size: 14.5px;
    color: var(--text-sec);
    line-height: 1.6;
  }
  .hero__steps li strong {
    color: var(--text);
    font-weight: 600;
  }
  .hero__step-n {
    font-weight: 700;
    font-size: 13px;
    color: var(--green);
    border: 1.5px solid var(--green);
    border-radius: 30px;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__panel-foot {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }
  .hero__panel-foot span {
    font-weight: 600;
    font-size: 13px;
    color: var(--green);
    letter-spacing: 0.02em;
  }

  /* Reel visual — mobile first */
  .section--reel {
    background: var(--surface);
  }
  .reel__wrap {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .reel__video {
    display: block;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 9 / 16;
    border-radius: 8px;
    background: #000;
    margin: 0 auto;
  }

  /* Programas premium */
  .progs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 32px;
  }
  .progs__item {
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
  }
  .progs__item--featured {
    border-color: var(--green);
    box-shadow: 0 0 0 1px var(--green);
  }
  .progs__tag {
    display: inline-block;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-accent);
    margin-bottom: 14px;
  }
  .progs__tag--light {
    color: #fff;
    background: var(--green);
    padding: 3px 10px;
    border-radius: 30px;
  }
  .progs__title {
    font-weight: 700;
    font-size: 20px;
    color: var(--text);
    margin: 0 0 6px;
    line-height: 1.25;
  }
  .progs__meta {
    font-weight: 600;
    font-size: 12.5px;
    color: var(--green);
    margin: 0 0 16px;
    letter-spacing: 0.02em;
  }

  /* Qué hacemos — 3 líneas principales */
  .qh-main {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 18px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .qh-main__item {
    padding: 30px 26px 30px 0;
    border-right: 1px solid var(--line);
  }
  .qh-main__item:last-child {
    border-right: none;
    padding-right: 0;
  }
  .qh-main__num {
    display: block;
    font-weight: 700;
    font-size: 30px;
    color: var(--green);
    opacity: 0.35;
    line-height: 1;
    margin-bottom: 18px;
  }
  .qh-main__title {
    font-weight: 700;
    font-size: 19px;
    color: var(--text);
    margin: 0 0 10px;
    line-height: 1.3;
  }

  /* Servicios complementarios — discretos */
  .qh-comp {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 16px 28px;
    margin-top: 26px;
    padding-top: 22px;
  }
  .qh-comp__label {
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-sec);
    white-space: nowrap;
  }
  .qh-comp__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
  }
  .qh-comp__list li {
    font-weight: 500;
    font-size: 13.5px;
    color: var(--text-sec);
    padding: 7px 16px;
    border: 1px solid var(--line);
    border-radius: 30px;
  }

  /* Filosofía — sección de contraste verde oscuro */
  .section--dark {
    background: var(--green-dark);
    border-bottom: none;
  }
  .dark__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: center;
  }
