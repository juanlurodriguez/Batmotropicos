---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { teamBuilding, EXTRA_NOTE, GROUP_LABELS } from '../data/teamBuilding';
import { BONIF_NOTE } from '../data/catalogo';

const groups: Array<TeamBuildingExperience['group']> = ['cohesion', 'activo', 'evento'];

type TeamBuildingExperience = import('../data/teamBuilding').TeamBuildingExperience;

const byGroup = (g: TeamBuildingExperience['group']) => teamBuilding.filter((e) => e.group === g);
---

<BaseLayout
  title="Team building y experiencias de cohesión"
  description="Experiencias de team building para empresas: cohesión, actividades deportivas, eventos corporativos y celebraciones. Dinámicas adaptadas al equipo, presenciales y a medida."
  path="/team-building"
>
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:760px">
        <p class="eyebrow">Team building</p>
        <h1 class="h2" style="font-size:38px">Experiencias que activan, conectan y hacen equipo</h1>
        <p class="lead">
          Desde dinámicas de cohesión hasta eventos de empresa con producción completa. Cada experiencia
          se diseña en función del tamaño del grupo, el momento de la organización y los objetivos
          que la empresa quiere trabajar.
        </p>
      </div>

      {
        groups.map((g) => (
          <div class="tb-group">
            <h2 class="tb-group__title reveal">{GROUP_LABELS[g]}</h2>
            <div class="tb">
              {byGroup(g).map((e) => (
                <article class="tb__card card card--accent reveal">
                  <div class="tb__top">
                    <h3 class="tb__title">{e.name}</h3>
                    <span class="tb__dur">{e.dur}</span>
                  </div>
                  <span class="badge tb__obj">{e.objetivo}</span>
                  <p class="card-text tb__desc">{e.desc}</p>
                  {e.extra && <p class="note tb__extra">{EXTRA_NOTE}</p>}
                </article>
              ))}
            </div>
          </div>
        ))
      }

      <p class="note reveal" style="margin-top:24px; max-width:740px">{BONIF_NOTE}</p>
    </div>
  </section>

  <CTASection
    eyebrow="Diseñamos tu experiencia"
    title="Cuéntanos qué necesita el equipo"
    text="Cada propuesta parte de cero: cuántos sois, qué momento vive el equipo y qué quieres conseguir. Te proponemos la experiencia que mejor encaja."
    primaryLabel="Solicitar propuesta de team building"
  />
</BaseLayout>

<style>
  .tb-group {
    margin-top: 48px;
  }
  .tb-group__title {
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-sec);
    margin: 0 0 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }
  .tb {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .tb__card {
    padding: 26px 26px 24px;
    display: flex;
    flex-direction: column;
  }
  .tb__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
  }
  .tb__title {
    font-weight: 700;
    font-size: 18px;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
  }
  .tb__dur {
    font-weight: 500;
    font-size: 12.5px;
    color: var(--text-sec);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tb__obj {
    align-self: flex-start;
    margin: 12px 0 14px;
    color: var(--green-accent);
    border-color: var(--green);
  }
  .tb__desc {
    font-size: 15px;
    flex: 1;
  }
  .tb__extra {
    margin-top: 12px;
  }

  @media (max-width: 720px) {
    .tb {
      grid-template-columns: 1fr;
    }
  }
</style>
