---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { catalogo, BONIF_NOTE } from '../data/catalogo';

const areas = [
  {
    t: 'Formación bonificable',
    d: 'Acciones presenciales y online diseñadas para encajar en el crédito FUNDAE de la empresa: salud, habilidades, prevención y cumplimiento.',
  },
  {
    t: 'Bienestar laboral',
    d: 'Ergonomía, gestión del estrés, comunicación y hábitos saludables aplicados al puesto real del equipo.',
  },
  {
    t: 'Productividad, liderazgo y coaching',
    d: 'Programas de desarrollo para mandos, equipos de alto rendimiento y organizaciones que quieren mejorar cómo funcionan por dentro.',
  },
  {
    t: 'Team building y cohesión',
    d: 'Experiencias diseñadas para activar, conectar y reforzar el sentimiento de equipo, adaptadas al tamaño del grupo y al momento de la organización.',
  },
  {
    t: 'Wellness in company',
    d: 'Fisioterapia, psicología, yoga, pausas activas, movilidad y recuperación en las instalaciones de la empresa. Con modelos flexibles: sesiones recurrentes, bolsa de horas mensual o copago empresa-trabajador.',
  },
  {
    t: 'Formación técnica y obligatoria',
    d: 'Cursos técnicos y de cumplimiento normativo (PRL, primeros auxilios, igualdad…) con su documentación gestionada y ordenada.',
  },
];

const beneficios = [
  ['Reduce el desgaste físico y mental', 'Menos molestias musculoesqueléticas, menos estrés crónico y más energía disponible en la jornada.'],
  ['Disminuye el absentismo', 'Las intervenciones preventivas reducen bajas y ausencias por causas relacionadas con el entorno de trabajo.'],
  ['Mejora el clima y la colaboración', 'Un equipo que se cuida discute menos y coopera mejor. El clima laboral tiene impacto directo en los resultados.'],
  ['Refuerza el sentimiento de pertenencia', 'Cuando la empresa cuida a su equipo de forma real, las personas se quedan. El salario emocional importa.'],
  ['Atrae y retiene talento', 'El bienestar corporativo es un argumento diferencial frente a empresas que solo ofrecen sueldo y condiciones estándar.'],
  ['Centraliza la gestión de servicios', 'Un solo equipo para formación, bienestar y cohesión. Menos contratos, menos coordinación dispersa.'],
];

const proceso = [
  ['Diagnóstico', 'Analizamos las necesidades reales del equipo y de la empresa.'],
  ['Diseño', 'Proponemos un plan a medida con acciones, formato y calendario.'],
  ['Gestión FUNDAE previa', 'Si aplica, revisamos el encaje en el crédito formativo y preparamos la documentación antes de ejecutar.'],
  ['Ejecución', 'Impartimos las acciones, presenciales u online, con profesionales especializados.'],
  ['Medición y cierre', 'Recogemos KPIs de bienestar, feedback del equipo y entregamos una memoria de resultados útil para la dirección.'],
];

const fundaeFaqs = [
  [
    '¿La formación tiene coste?',
    'Sí. Toda formación tiene un coste real. Lo que ocurre es que muchas acciones pueden bonificarse a través del crédito formativo del que dispone cada empresa, lo que puede reducir —o en algunos casos eliminar— el coste neto.',
  ],
  [
    '¿Qué es el crédito formativo FUNDAE?',
    'Es el crédito anual que cada empresa puede destinar a la formación de sus trabajadoras y trabajadores. Su importe depende de las cotizaciones a la Seguridad Social del ejercicio anterior. No es ilimitado: depende del tamaño de la empresa y del número de acciones.',
  ],
  [
    '¿Puede llegar a coste cero para la empresa?',
    'En determinados casos sí, cuando el crédito es suficiente y la acción cumple todos los requisitos. No es una garantía, pero es una posibilidad real que revisamos desde el primer momento.',
  ],
  [
    '¿Batmotrópicos gestiona la documentación?',
    'Sí. Revisamos el encaje de cada acción, preparamos la documentación conforme a la normativa vigente y acompañamos los plazos para que todo quede en regla antes de empezar.',
  ],
];
---

<BaseLayout
  title="Qué hacemos"
  description="Formación bonificable, bienestar laboral, team building y wellness in company para empresas. Un equipo que diseña, ejecuta y mide lo que el equipo necesita."
  path="/que-hacemos"
>
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:760px">
        <p class="eyebrow">Qué hacemos</p>
        <h1 class="h2" style="font-size:38px">Una sola propuesta para cuidar, formar y cohesionar al equipo</h1>
        <p class="lead">
          Centralizamos formación, bienestar y cohesión en una propuesta coordinada, con menos
          proveedores que gestionar y más coherencia en lo que se hace.
        </p>
      </div>

      <div class="rows">
        {
          areas.map((a, i) => (
            <div class="row reveal">
              <span class="row__num">0{i + 1}</span>
              <div class="row__body">
                <h2 class="row__title">{a.t}</h2>
                <p class="card-text" style="font-size:15.5px">{a.d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="section section--soft">
    <div class="wrap">
      <div class="reveal" style="max-width:740px">
        <p class="eyebrow">Beneficios</p>
        <h2 class="h2">Lo que gana la empresa</h2>
        <p class="lead">
          No son actividades sueltas: es una forma estructurada de cuidar al equipo que repercute en
          clima, retención y rendimiento.
        </p>
      </div>
      <div class="ben">
        {
          beneficios.map(([t, d], i) => (
            <div class="ben__item reveal">
              <span class="ben__num">0{i + 1}</span>
              <div>
                <h3 class="ben__title">{t}</h3>
                <p class="card-text">{d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Método -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:740px">
        <p class="eyebrow">Cómo trabajamos</p>
        <h2 class="h2">Del diagnóstico a los resultados</h2>
        <p class="lead">
          Cinco pasos que van desde el análisis inicial hasta el cierre documentado, con la gestión
          de bonificación resuelta antes de ejecutar.
        </p>
      </div>
      <ol class="method">
        {
          proceso.map(([t, d], i) => (
            <li class="method__step reveal">
              <span class="method__dot">{i + 1}</span>
              <div>
                <h3 class="method__title">{t}</h3>
                <p class="card-text">{d}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- FUNDAE FAQ -->
  <section class="section section--soft">
    <div class="wrap">
      <div class="reveal" style="max-width:740px">
        <p class="eyebrow">Bonificación FUNDAE</p>
        <h2 class="h2">Lo que conviene saber antes de planificar</h2>
        <p class="lead">
          La formación tiene un coste real. Muchas acciones pueden bonificarse mediante el crédito
          formativo de la empresa. Aquí aclaramos las dudas más habituales.
        </p>
      </div>
      <div class="faq">
        {
          fundaeFaqs.map(([q, a]) => (
            <details class="faq__item reveal">
              <summary class="faq__q">{q}</summary>
              <p class="faq__a">{a}</p>
            </details>
          ))
        }
      </div>
      <div class="reveal" style="margin-top:20px">
        <a href="/fundae" class="btn btn--outline">Ver más sobre bonificación FUNDAE <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- Áreas del catálogo -->
  <section class="section">
    <div class="wrap">
      <div class="reveal">
        <p class="eyebrow">Catálogo</p>
        <h2 class="h2">Áreas que cubrimos</h2>
      </div>
      <div class="tags reveal">
        {catalogo.map((c) => <a href="/catalogo" class="tag">{c.tab} · {c.items.length}</a>)}
      </div>
      <div class="reveal" style="margin-top:24px">
        <a href="/catalogo" class="btn btn--primary">Ver catálogo completo <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .rows {
    margin-top: 32px;
    border-top: 1px solid var(--line);
  }
  .row {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }
  .row__num {
    font-weight: 700;
    font-size: 22px;
    color: var(--line);
  }
  .row__title {
    font-weight: 700;
    font-size: 20px;
    color: var(--green);
    margin: 0 0 8px;
  }

  .ben {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 56px;
    margin-top: 30px;
    border-top: 1px solid var(--line);
  }
  .ben__item {
    display: flex;
    gap: 20px;
    padding: 26px 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }
  .ben__num {
    font-weight: 700;
    font-size: 15px;
    color: var(--green);
    min-width: 28px;
  }
  .ben__title {
    font-weight: 600;
    font-size: 17px;
    color: var(--text);
    margin: 0 0 6px;
    line-height: 1.35;
  }

  .method {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
  }
  .method__step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 24px;
    padding-bottom: 32px;
  }
  .method__step:last-child {
    padding-bottom: 0;
  }
  .method__dot {
    width: 44px;
    height: 44px;
    border-radius: 44px;
    border: 2px solid var(--green);
    color: var(--green);
    background: #fff;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .method__title {
    font-weight: 700;
    font-size: 18px;
    color: var(--text);
    margin: 0 0 6px;
  }

  .faq {
    margin-top: 28px;
    border-top: 1px solid var(--line);
  }
  .faq__item {
    border-bottom: 1px solid var(--line);
    padding: 4px 0;
  }
  .faq__q {
    font-weight: 600;
    font-size: 16px;
    color: var(--text);
    cursor: pointer;
    padding: 18px 36px 18px 0;
    position: relative;
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after {
    content: '+';
    position: absolute;
    right: 4px;
    top: 16px;
    font-size: 22px;
    font-weight: 400;
    color: var(--green);
  }
  .faq__item[open] .faq__q::after { content: '–'; }
  .faq__a {
    font-size: 15px;
    color: var(--text-sec);
    line-height: 1.7;
    margin: 0;
    padding: 0 36px 20px 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }
  .tag {
    font-weight: 600;
    font-size: 13.5px;
    color: var(--green);
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 9px 16px;
    text-decoration: none;
    background: #fff;
  }
  .tag:hover {
    border-color: var(--green);
  }

  @media (max-width: 980px) {
    .ben {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
