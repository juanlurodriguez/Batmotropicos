---
// Símbolo Batmotrópicos (corazón + rayo + B). SVG inline para poder
// colorear con currentColor y animar el trazado en el hero.
interface Props {
  size?: number;
  /** Activa la animación de dibujado + pulso */
  draw?: boolean;
  class?: string;
}
const { size = 64, draw = false, class: className } = Astro.props;
const P1 =
  'M 745 280 L 654 403 L 587 489 L 647 510 L 648 513 L 411 736 L 327 818 L 454 735 L 457 735 L 473 743 L 503 754 L 539 763 L 581 768 L 609 768 L 631 766 L 672 757 L 710 741 L 744 718 L 761 702 L 772 689 L 785 670 L 797 645 L 805 613 L 806 587 L 803 562 L 799 547 L 792 530 L 779 510 L 759 490 L 747 481 L 747 479 L 767 460 L 775 449 L 783 433 L 790 409 L 791 376 L 786 349 L 778 327 L 765 304 Z';
const P2 =
  'M 815 172 L 708 247 L 677 232 L 645 220 L 616 213 L 593 210 L 555 210 L 518 216 L 480 229 L 456 241 L 415 269 L 375 303 L 311 363 L 239 434 L 198 477 L 192 485 L 191 497 L 194 504 L 216 535 L 250 576 L 310 638 L 338 663 L 366 685 L 396 705 L 408 711 L 461 644 L 534 546 L 473 525 L 472 522 L 533 464 L 703 295 Z';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 1024 1024"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Batmotrópicos"
  class={[draw ? 'bm-pulse' : '', className].filter(Boolean).join(' ')}
  style="display:block; color: var(--green);"
>
  <path
    d={P1}
    class={draw ? 'bm-draw' : ''}
    fill="none"
    stroke="currentColor"
    stroke-width="12"
    stroke-linejoin="round"
    stroke-linecap="round"
    pathLength="1"
  ></path>
  <path
    d={P2}
    class={draw ? 'bm-draw bm-p2' : ''}
    fill="none"
    stroke="currentColor"
    stroke-width="12"
    stroke-linejoin="round"
    stroke-linecap="round"
    pathLength="1"
  ></path>
</svg>
