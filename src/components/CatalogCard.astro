---
import type { CatalogCategory } from '../data/catalogo';
import { EXTRA_NOTE } from '../data/teamBuilding';

interface Props {
  category: CatalogCategory;
}
const { category } = Astro.props;
---

<article class="cat card card--accent">
  <header class="cat__head">
    <div class="cat__heading">
      <span class="cat__letter" aria-hidden="true">{category.letter}</span>
      <div>
        <h3 class="cat__title">{category.title}</h3>
        <p class="cat__desc">{category.desc}</p>
      </div>
    </div>
    <span class="bonif-badge">{category.bonif}</span>
  </header>

  <ul class="cat__items">
    {
      category.items.map((item) => (
        <li class="cat__item">
          <div class="cat__item-main">
            <span class="cat__item-name">{item.name}</span>
            {item.note && <span class="cat__item-note">{item.note}</span>}
            {item.extra && <span class="cat__item-extra">{EXTRA_NOTE}</span>}
          </div>
          {item.dur && <span class="cat__item-dur">{item.dur}</span>}
        </li>
      ))
    }
  </ul>

  <a href="/contacto" class="btn btn--outline btn--sm cat__cta">
    Solicitar propuesta de esta área <span class="arrow">→</span>
  </a>
</article>

<style>
  .cat {
    padding: 30px 30px 28px;
  }
  .cat__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .cat__heading {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .cat__letter {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border: 1.5px solid var(--green);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    color: var(--green);
  }
  .cat__title {
    font-weight: 700;
    font-size: 21px;
    color: var(--text);
    margin: 0 0 8px;
    line-height: 1.25;
  }
  .cat__desc {
    font-size: 15px;
    color: var(--text-sec);
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }
  .cat__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 40px;
    border-top: 1px solid var(--line);
  }
  .cat__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
  }
  .cat__item-main {
    display: flex;
    flex-direction: column;
  }
  .cat__item-name {
    font-weight: 500;
    font-size: 15px;
    color: var(--text);
    line-height: 1.4;
  }
  .cat__item:hover .cat__item-name {
    color: var(--green);
  }
  .cat__item-note {
    font-size: 13px;
    color: var(--text-sec);
    line-height: 1.5;
    margin-top: 3px;
  }
  .cat__item-extra {
    font-size: 12px;
    color: var(--text-sec);
    font-style: italic;
    margin-top: 4px;
  }
  .cat__item-dur {
    font-weight: 500;
    font-size: 12.5px;
    color: var(--text-sec);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cat__cta {
    margin-top: 24px;
  }

  @media (max-width: 720px) {
    .cat {
      padding: 24px 20px;
    }
    .cat__items {
      grid-template-columns: 1fr;
    }
  }
</style>
